# Email Configuration
SMTP_URL=smtp://smtp.gmail.com:587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=matteopennacchia43@gmail.com
SMTP_USE_TLS=true
SMTP_SKIP_TLS_VERIFY=false
SMTP_VERBOSE=false

# Database
DATABASE_PATH=./database/devnav.db

# Email Extraction
EXTRACT_SOURCES=linkedin,github,email_lists
MAX_EMAILS_PER_BATCH=50

# Security
ENABLE_VIRUS_CHECK=true
ENABLE_SOURCE_VERIFICATION=true

# Email Data Sources (API Keys)
# HUNTER.IO - https://hunter.io
HUNTER_IO_API_KEY=

# APOLLO.IO - https://apollo.io
APOLLO_API_KEY=

# CLEARBIT - https://clearbit.com
CLEARBIT_API_KEY=

# ROCKETREACH - https://rocketreach.com
ROCKETREACH_API_KEY=

# IP Geolocation (MaxMind) - https://maxmind.com
MAXMIND_API_KEY=

# IP Quality Score - https://ipqualityscore.com
IPQS_API_KEY=

# Geo-Targeting
TARGET_COUNTRIES=US,UK,CA,AU
BLOCK_VPN=true
BLOCK_PROXIES=true
BLOCK_BOTS=true
