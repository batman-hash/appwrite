# Email Configuration
SMTP_URL=smtp://smtp.gmail.com:587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=matteopennacchia43@gmail.com
SMTP_USE_TLS=true
SMTP_SKIP_TLS_VERIFY=false
SMTP_VERBOSE=false

# Database
DATABASE_PATH=./database/devnav.db

# Campaign registration links
# The sender will use the current template's specific link when available.
DEFAULT_REGISTER_LINK=
DEFAULT_CAMPAIGN_REGISTER_LINK=
JUNIOR_DEV_RECRUITMENT_REGISTER_LINK=
FREELANCE_OPPORTUNITIES_REGISTER_LINK=
MARKETING_PARTNERSHIP_REGISTER_LINK=
LEARNING_PROGRAM_REGISTER_LINK=
EARNING_OPPORTUNITY_REGISTER_LINK=

# Email Extraction
EXTRACT_SOURCES=linkedin,github,email_lists
MAX_EMAILS_PER_BATCH=50

# Security
ENABLE_VIRUS_CHECK=true
ENABLE_SOURCE_VERIFICATION=true
EMAIL_VALIDATION_DNS_TIMEOUT=4
EMAIL_VALIDATION_STRICT_DNS=false
EMAIL_VERIFICATION_BASE_URL=
EMAIL_VERIFICATION_EXPIRY_HOURS=48

# Email Data Sources (API Keys) - Optional
# Leave empty to use free tier

# HUNTER.IO - https://hunter.io (optional, $99/month)
HUNTER_API_KEY=

# APOLLO.IO - https://apollo.io (optional, $99/month)
APOLLO_API_KEY=

# CLEARBIT - https://clearbit.com (optional, expensive)
CLEARBIT_API_KEY=

# ROCKETREACH - https://rocketreach.com (optional)
ROCKETREACH_API_KEY=

# Geo-Targeting - FREE TIER (no API keys needed!)
# Using free services: IP-API.COM, IPify, GeoIP-DB
# All completely free, unlimited, no registration
FREE_GEOIP_ENABLED=true
CACHE_GEOIP_RESULTS=true
TARGET_COUNTRIES=US,UK,CA,AU

# Optional: Premium geo services (leave empty for free tier)
MAXMIND_API_KEY=
IPQS_API_KEY=
