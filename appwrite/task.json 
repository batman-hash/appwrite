{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "docker-build",
      "type": "docker-build",
      "dockerBuild": {
        "tag": "my-app",
        "dockerfile": "${workspaceFolder}/Dockerfile",
        "context": "${workspaceFolder}"
      }
    },
    {
      "label": "docker-run: debug",
      "type": "docker-run",
      "dependsOn": ["docker-build"],
      "dockerRun": {
        "containerName": "my-app-container",
        "image": "my-app"
      }
    }
  ]
}