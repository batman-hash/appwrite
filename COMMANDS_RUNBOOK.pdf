T* (    SEARCH_MAX_PROCESS_COUNT=800 \\) Tj
T* (    SEARCH_MAX_SINGLE_PROCESS_CPU_PERCENT=25 \\) Tj
T* (    SEARCH_WARN_ONLY_PROCESS_NAMES=code,gnome-shell \\) Tj
