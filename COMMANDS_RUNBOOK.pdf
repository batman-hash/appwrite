() Tj
T* () Tj
T* (    # Initialize the database in the mounted project folder) Tj
T* (    docker run --rm -it -v "$\(pwd\):/workspace" devnavigator init-db) Tj
T* () Tj
T* () Tj
T* (    # Extract and save emails from a local file using Docker) Tj
T* (    docker run --rm -it -v "$\(pwd\):/workspace" devnavigator \\) Tj
T* (      extract-emails --file sample_emails.csv --store --source manual) Tj
T* () Tj
T* () Tj
T* (    # Check stats and queue using Docker) Tj
T* (    docker run --rm -it -v "$\(pwd\):/workspace" devnavigator stats) Tj
T* (    docker run --rm -it -v "$\(pwd\):/workspace" devnavigator queue --queue all --limit 20) Tj
T* () Tj
T* () Tj
T* (    # Validate one email using Docker) Tj
T* (    docker run --rm -it -v "$\(pwd\):/workspace" devnavigator \\) Tj
T* (      validate-email --email person@example.com) Tj
T* () Tj
T* () Tj
T* (Comment:) Tj
T* (The Docker image runs devnavigator.py directly. Mounting the repo to /workspace gives the) Tj
T* (container access to your local .env, files, and database folder.) Tj
T* () Tj
T* (EXTRACT EMAILS FROM A FILE) Tj
T* (--------------------------) Tj
T* () Tj
T* (    # Extract emails from any text-like file and store them in the database) Tj
T* (    python3 devnavigator.py extract-emails --file your_file.txt --store --source manual) Tj
T* () Tj
T* () Tj
T* (    # Example using the helper shell script) Tj
T* (    ./extract-emails.sh your_file.txt) Tj
T* () Tj
T* () Tj
T* (Comment:) Tj
T* (This path validates emails before saving them. Invalid addresses are skipped and shown in) Tj
T* (the output.) Tj
T* () Tj
T* (IMPORT A STRUCTURED CSV) Tj
T* (-----------------------) Tj
T* () Tj
T* (    # Import a CSV file that has an email column) Tj
T* (    python3 devnavigator.py import-contacts --file your_contacts.csv --source csv_upload) Tj
T* () Tj
T* () Tj
T* (    # Import and mark contacts as approved/sendable immediately) Tj
ET
endstream
endobj
