# AI Provider Configuration Template
# Add your API keys here one by one
# WARNING: Never commit this file to git - use .env.local in production

# ============================================================================
# FREE API PROVIDERS
# ============================================================================

# Gemini (Google AI) - Free tier + paid
GEMINI_API_KEY=AIzaSyBRjCei33lZ3cZCWLwGYKFtm8_cpoAkHwc

# Groq - Free tier + paid development plan  
GROQ_API_KEY=your_groq_api_key_here

# Hugging Face - Limited free inference + paid
HF_TOKEN=your_huggingface_token_here

# Together AI - Free tier, OpenAI-compatible
TOGETHER_API_KEY=your_together_api_key_here

# Replicate - Free tier with monthly credits
REPLICATE_API_TOKEN=your_replicate_token_here

# ============================================================================
# FREEMIUM / MIXED (Free + Paid Options)
# ============================================================================

# Mistral AI - Free API access + paid options
MISTRAL_API_KEY=your_mistral_api_key_here

# OpenRouter - Free models/limits + paid credits
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Kilo Code - Free tier, auto-model switching
KILO_API_KEY=your_kilo_api_key_here

# ============================================================================
# TRIAL / EVALUATION
# ============================================================================

# Cohere - Trial keys + paid production
COHERE_API_KEY=your_cohere_api_key_here

# ============================================================================
# PAID API PROVIDERS (Require billing setup)
# ============================================================================

# OpenAI - Paid API (pay per token)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (Claude) - Paid API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================================================
# OPTIONAL: Default provider to use
# ============================================================================

# Set which provider to use by default
# Default: gemini (free tier)
DEFAULT_PROVIDER=gemini

# ============================================================================
# OPTIONAL: Logging and Debug
# ============================================================================

# Enable debug logging
DEBUG=false

# Log API requests and responses
LOG_REQUESTS=false

# ============================================================================
# HELPFUL NOTES
# ============================================================================
# 
# Recommended free options to start:
#   1. GEMINI_API_KEY - Best overall free tier
#   2. GROQ_API_KEY - Super fast, free tier
#   3. TOGETHER_API_KEY - Good for local-style models
#
# Recommended production (pay-as-you-go):
#   1. OPENAI_API_KEY - Most stable, best models
#   2. ANTHROPIC_API_KEY - Great for reasoning tasks
#   3. MISTRAL_API_KEY - Good European alternative
#
# Get your keys at:
#   Gemini:     https://aistudio.google.com
#   Groq:       https://console.groq.com/keys
#   OpenAI:     https://platform.openai.com/api-keys
#   Anthropic:  https://console.anthropic.com
#   Mistral:    https://console.mistral.ai
#   Kilo:       https://kilo.ai/dashboard
